### LLM / AI safe defaults (copy to .env or set in your deployment)
# By default remote LLM calls are disabled. To enable, set VITE_ENABLE_LLM=true
VITE_ENABLE_LLM=false
# URL to your LLM proxy endpoint (leave empty to disable remote calls)
VITE_LLM_ENDPOINT=
# Model identifier used by your endpoint (optional)
VITE_LLM_MODEL=gpt-4o-mini
# Max tokens for remote calls (keep small to save cost)
VITE_LLM_MAX_TOKENS=80
# Percent price change required to trigger a remote analysis
VITE_LLM_PRICE_DELTA_PERCENT=0.5
# Minimum number of new comments to trigger remote analysis
VITE_LLM_COMMENT_DELTA=3
# Cache TTL (seconds) for LLM results
VITE_LLM_CACHE_TTL_SEC=600